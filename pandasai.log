import pandas as pd
import matplotlib.pyplot as plt

# SQL query to get total money spent by each team
sql_query = """
SELECT Team, SUM("COST IN ₹ (CR.)") AS Total_Spent_Cr
FROM table_a1d2f5d18660a5b44142666b3bd95e40
GROUP BY Team
ORDER BY Total_Spent_Cr DESC
"""
df_team_spent = execute_sql_query(sql_query)

# Plotting the bar graph
plt.figure(figsize=(10,6))
plt.bar(df_team_spent['Team'], df_team_spent['Total_Spent_Cr'], color='skyblue')
plt.xlabel('Team')
plt.ylabel('Total Money Spent (₹ Crores)')
plt.title('Total Money Spent by Each Team This Season')
plt.xticks(rotation=45, ha='right')
plt.tight_layout()

# Save plot to a file
plot_filename = "team_spending_bargraph.png"
plt.savefig(plot_filename)
plt.close()

result = {"type": "plot", "value": plot_filename}
