import pandas as pd
import matplotlib.pyplot as plt

# Load full dataset
sql_all_data = """
SELECT *
FROM table_a1d2f5d18660a5b44142666b3bd95e40
"""
df = execute_sql_query(sql_all_data)

# Multivariate analysis: Explore relationships between TYPE, Team, and Cost in ₹ (CR.)
# 1. Average cost by TYPE and Team
sql_avg_cost_type_team = """
SELECT TYPE, Team, 
       AVG("COST IN ₹ (CR.)") AS avg_cost_cr,
       COUNT(*) AS player_count
FROM table_a1d2f5d18660a5b44142666b3bd95e40
GROUP BY TYPE, Team
ORDER BY TYPE, avg_cost_cr DESC
"""
avg_cost_type_team = execute_sql_query(sql_avg_cost_type_team)

# 2. Correlation between COST IN ₹ (CR.) and COST IN $ (000)
# Since these are directly proportional, just calculate correlation coefficient
cost_corr = df['COST IN ₹ (CR.)'].corr(df['Cost IN $ (000)'])

# 3. Pivot table for average cost by TYPE and Team for heatmap visualization
pivot_avg_cost = avg_cost_type_team.pivot(index='TYPE', columns='Team', values='avg_cost_cr').fillna(0)

# Plot heatmap of average cost by TYPE and Team
plt.figure(figsize=(12, 6))
plt.title('Average Cost in ₹ (CR.) by Player Type and Team')
plt.imshow(pivot_avg_cost, cmap='YlGnBu', aspect='auto')
plt.colorbar(label='Avg Cost ₹ (CR.)')
plt.xticks(ticks=range(len(pivot_avg_cost.columns)), labels=pivot_avg_cost.columns, rotation=45, ha='right')
plt.yticks(ticks=range(len(pivot_avg_cost.index)), labels=pivot_avg_cost.index)
plt.tight_layout()
heatmap_path = 'exports/charts/avg_cost_type_team_heatmap.png'
plt.savefig(heatmap_path)
plt.close()

# 4. Boxplot to show distribution of COST IN ₹ (CR.) by TYPE
plt.figure(figsize=(8, 5))
df.boxplot(column='COST IN ₹ (CR.)', by='TYPE', grid=False)
plt.title('Cost in ₹ (CR.) Distribution by Player Type')
plt.suptitle('')
plt.xlabel('Player Type')
plt.ylabel('Cost in ₹ (CR.)')
plt.xticks(rotation=45)
plt.tight_layout()
boxplot_path = 'exports/charts/cost_distribution_by_type.png'
plt.savefig(boxplot_path)
plt.close()

# Prepare summary dataframe for multivariate insights
summary_multivariate = pd.DataFrame({
    'Metric': [
        'Correlation between COST IN ₹ (CR.) and COST IN $ (000)',
        'Number of Player Types',
        'Number of Teams',
        'Total Players'
    ],
    'Value': [
        cost_corr,
        df['TYPE'].nunique(),
        df['Team'].nunique(),
        len(df)
    ]
})

# Return results as dictionary with multiple outputs:
# - Dataframe summarizing multivariate stats
# - Heatmap plot path
# - Boxplot plot path

result = {
    "type": "dataframe",
    "value": summary_multivariate
}
