# Summary statistics for numeric columns
sql_summary_stats = """
SELECT 
  COUNT(*) AS total_records,
  AVG("COST IN ₹ (CR.)") AS avg_cost_cr,
  MIN("COST IN ₹ (CR.)") AS min_cost_cr,
  MAX("COST IN ₹ (CR.)") AS max_cost_cr,
  AVG("Cost IN $ (000)") AS avg_cost_usd,
  MIN("Cost IN $ (000)") AS min_cost_usd,
  MAX("Cost IN $ (000)") AS max_cost_usd
FROM table_a1d2f5d18660a5b44142666b3bd95e40
"""
summary_stats = execute_sql_query(sql_summary_stats)

# Frequency counts for categorical columns: TYPE, Team, 2022 Squad
sql_type_counts = """
SELECT TYPE, COUNT(*) AS count
FROM table_a1d2f5d18660a5b44142666b3bd95e40
GROUP BY TYPE
ORDER BY count DESC
"""
type_counts = execute_sql_query(sql_type_counts)

sql_team_counts = """
SELECT Team, COUNT(*) AS count
FROM table_a1d2f5d18660a5b44142666b3bd95e40
GROUP BY Team
ORDER BY count DESC
"""
team_counts = execute_sql_query(sql_team_counts)

sql_squad_counts = """
SELECT "2022 Squad", COUNT(*) AS count
FROM table_a1d2f5d18660a5b44142666b3bd95e40
WHERE "2022 Squad" IS NOT NULL AND "2022 Squad" != ''
GROUP BY "2022 Squad"
ORDER BY count DESC
"""
squad_counts = execute_sql_query(sql_squad_counts)

# Plot distribution of COST IN ₹ (CR.)
